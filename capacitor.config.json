{
  "appId": "io.routineflow.app",
  "appName": "RoutineFlow",
  "webDir": "www",
  "backgroundColor": "#080810",
  "ios": {
    "contentInset": "always",
    "preferredContentMode": "mobile",
    "backgroundColor": "#080810",
    "allowsLinkPreview": false
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#f97316",
      "sound": "default"
    }
  },
  "server": {
    "iosScheme": "https",
    "hostname": "localhost",
    "androidScheme": "https",
    "allowNavigation": [
      "*.firebaseapp.com",
      "*.googleapis.com",
      "*.gstatic.com",
      "api.telegram.org"
    ]
  }
}
